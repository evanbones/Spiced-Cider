      "${namespace}:${stripped}${wood}_palisade",
      "${namespace}:${stripped}spiked_${wood}_palisade",
      "valhelsia_structures:${stripped}${wood}_post",
      "valhelsia_structures:cut_${stripped}${wood}_post",
      "${namespace}:${stripped}${wood}_post",
      "${namespace}:cut_${stripped}${wood}_post",
      "everycomp:vs/${namespace}/${stripped}${wood}_post",
      "everycomp:vs/${namespace}/cut_${stripped}${wood}_post"
    ],
    "/(?<prefix>everycomp|spicedcider):(?<dir>[^/]+)/(?<namespace>[^/]+)/(?<stripped>stripped_)?(?!spiked_)(?<wood>.+)_palisade/": [
      "${prefix}:${dir}/${namespace}/${stripped}${wood}_palisade",
      "${prefix}:${dir}/${namespace}/${stripped}spiked_${wood}_palisade",
      "valhelsia_structures:${stripped}${wood}_post",
      "valhelsia_structures:cut_${stripped}${wood}_post",
      "${namespace}:${stripped}${wood}_post",
      "${namespace}:cut_${stripped}${wood}_post",
      "everycomp:vs/${namespace}/${stripped}${wood}_post",
      "everycomp:vs/${namespace}/cut_${stripped}${wood}_post"
    ],
    "/(?<namespace>[^:]+):(?<wood>.+)_log/": [
      "valhelsia_structures:bundled_${wood}_posts",
      "${namespace}:bundled_${wood}_posts",
      "everycomp:vs/${namespace}/bundled_${wood}_posts"
    ],
    "/(?<namespace>[^:]+):(?<wood>.+)_stem/": [
      "valhelsia_structures:bundled_${wood}_posts",
      "${namespace}:bundled_${wood}_posts",
      "everycomp:vs/${namespace}/bundled_${wood}_posts"
    ]
  }
